@bot.message_handler(commands=['getfile'])
def ask_file_name(message):
    chat_id = str(message.chat.id)
    if chat_id in daily_db and daily_db[chat_id]:
        msg = bot.send_message(message.chat.id, "📂 **ওরে আমার মুরগী চোর মামা রে!**\nআজকে তো কোপাইছো! তা ফাইলের নামটা কী দিমু কও?")
        bot.register_next_step_handler(msg, process_file_name)
    else:
        bot.send_message(message.chat.id, "❌ **ধুর মামা!**\nপকেটে নাই আনা, খাইতে চাও খানা? আগে কাম করো, আইডির লিস্ট তো খালি!")

def process_file_name(message):
    if message.text.startswith('/'): return 
    user_input = message.text.strip()
    clean_name = re.sub(r'[\\/*?:"<>|]', '_', user_input)
    chat_id = str(message.chat.id)
    full_path = f"{clean_name}.xlsx"
    
    try:
        workbook = xlsxwriter.Workbook(full_path)
        worksheet = workbook.add_worksheet()
        for i, row in enumerate(daily_db[chat_id]): 
            worksheet.write_row(i, 0, row)
        workbook.close()
        
        bot.send_message(message.chat.id, f"⏳ **একটু সবুর করো মামা...**\n👉{clean_name}📁 নামে এক্সেল বানায়া দিতাছি।")
        with open(full_path, "rb") as f:
            bot.send_document(message.chat.id, f, caption=f"📊 **এই নাও মামা তোমার মাল!**\nফাইলের নাম: 👉 {clean_name}.xlsx 😮‍💨 \n\nকোপাইয়া কাম করো! 🔥")
        os.remove(full_path)
    except Exception as e:
        bot.send_message(message.chat.id, f"💀 **ভুল হইছে মামা!**\nএরর: `{e}`")

